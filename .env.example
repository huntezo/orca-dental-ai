# ============================================
# Orca Dental AI - Environment Configuration
# ============================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Next.js Configuration
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deployment Mode
# Options: cloud, hybrid, onprem
DEPLOYMENT_MODE=cloud

# AI Worker Configuration
WORKER_ID=worker-1

# Edge Node Configuration
EDGE_REGION=us-east-1
EDGE_HMAC_SECRET=your-secret-key-for-edge-jobs

# Local Model Configuration
MODEL_VERSION=v1.0
CONFIDENCE_THRESHOLD=0.85
MAX_IMAGE_SIZE=2048

# Training Worker Configuration
DEFAULT_EPOCHS=10
BATCH_SIZE=8
LEARNING_RATE=0.0001
TRAINING_OUTPUT_DIR=/models/trained

# Monitoring
GRAFANA_PASSWORD=admin

# Optional: External AI Provider API Keys (for cloud mode)
# EXTERNAL_AI_API_KEY=your-api-key
# EXTERNAL_AI_ENDPOINT=https://api.external-ai.com

# On-Prem License (for onprem mode)
# LICENSE_KEY=your-license-key
